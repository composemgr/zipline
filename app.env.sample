# Zipline - app.env.sample
# Copy to app.env and adjust values before starting

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=$HOSTNAME

# Database credentials
DB_CREATE_DATABASE_NAME=zipline
DB_USER_NAME=zipline
DB_USER_PASS=changeme_db_password

# App secret (used for session/JWT signing, min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars

# Site title shown in the UI
APP_NAME=Zipline
